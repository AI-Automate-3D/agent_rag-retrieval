# Copy this file to config.yaml and fill in your values.
# Environment variables take priority over this file.

openai_api_key: "sk-your-api-key-here"
openai_model: "gpt-4o"
embedding_model: "text-embedding-3-small"

# Path to the directory containing knowledge base documents (.txt, .md files)
knowledge_base_path: "knowledge_base/documents"

# Path to a .txt file containing the system message (agent persona / behavior)
system_message_path: "system_message.txt"
